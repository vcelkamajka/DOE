file = pd.read_csv('DOE file.csv')
print(file)
print(dash)
print('You have',len(file.columns) - 1,'variable(s):')
for i in range(len(file.columns) - 1):
    print(file.columns[i])
print('Your response variable is:')
print(file.columns[-1])
print(dash)

factors = []
response = file.columns[-1]

for i in range(len(file.columns)-1):
    factors.append(file.columns[i])

x = file[factors]
y = file[response]


for n in range(1,4):
    print('Assuming', n, 'order')
    poly = PolynomialFeatures(n, include_bias=False)
    x_poly = poly.fit_transform(x)
    model = LinearRegression()
    model.fit(x_poly,y)
    y_pred = model.predict(x_poly)

    r2 = r2_score(y, y_pred)
    mse = mean_squared_error(y, y_pred)

    print('Model coefficients: ', model.coef_)  # Beta coefficients
    print("Intercept:", model.intercept_)
    print(f'Correlation coefficient is: {r2:.4f}')
    print(f'Root mean squared error is {mse ** 0.5:.4f}')
    print(dash)

    # Source: https://machinelearningmastery.com/calculate-feature-importance-with-python/

    importance = model.coef_
    for i, v in enumerate(importance):
        print('Feature: %0d, Score: %.5f' % (i, v))

    poly_feature_names = poly.get_feature_names_out(x.columns)
    print("Feature names:", poly_feature_names)

    fig, ax = plt.subplots(constrained_layout=True)
    fig.set_constrained_layout_pads(hspace=10,
                                    wspace=10)

    ax.bar([x for x in range(len(importance))], importance)
    plt.xticks(np.arange(0, len(importance)),[tick for tick in poly_feature_names], rotation='vertical')

    #plt.xlim(0,len(importance))
    plt.plot([0,len(importance)-1],[0,0], color='k', lw = 0.5)
    plt.axhline(0, color='k',lw=0.5)
    plt.ylabel('Importance')

    plt.show()

    print(dash)

reg = ['First Order', 'Second Order', 'Third Order']

if (len(file.columns) -1) == 3: # 3 variables
    for n in range(0, 3):
        poly = PolynomialFeatures(n + 1, include_bias=False)
        x_train = poly.fit_transform(x)
        model = LinearRegression()
        model.fit(x_train, y)

        c = y_pred

        x0 = np.linspace(file.iloc[:,0].min(), file.iloc[:,0].max(), 15).ravel()
        x1 = np.linspace(file.iloc[:,1].min(), file.iloc[:,1].max(), 15).ravel()
        x2 = np.linspace(file.iloc[:,2].min(), file.iloc[:,2].max(), 15).ravel()

        [x1, x2, x3] = np.meshgrid(x0, x1, x2)

        a = [x1,x2,x3]
        flat = np.column_stack([x1.ravel(), x2.ravel(), x3.ravel()])

        res = poly.fit_transform(flat)
        c = model.predict(res)

        fig, ax = plt.subplots(subplot_kw ={'projection': '3d'})

        norm = Normalize(vmin = c.min(), vmax = c.max())
        colours = cm.inferno(norm(c))

        surface = ax.scatter(x1, x2, x3, facecolors = colours, linewidth = 0, s = 300, marker = 'o', alpha = 1)
        mappable = cm.ScalarMappable(norm = norm, cmap = 'inferno')
        mappable.set_array(c)

        fig.colorbar(mappable, ax = ax, shrink = 0.5, label = file.columns[-1])
        ax.set_xlabel(file.columns[0])
        ax.set_ylabel(file.columns[1])
        ax.set_zlabel(file.columns[2])
        ax.set_title(reg[n])

    plt.show()

if len(file.columns) - 1 == 2:
    # x, y will form the axes and the response will be coloured (contourf plot)

    x0 = np.linspace(file.iloc[:,0].min(), file.iloc[:,0].max(), 15).ravel()
    x1 = np.linspace(file.iloc[:,1].min(), file.iloc[:,1].max(), 15).ravel()

    x_flat, y_flat = np.meshgrid(x0, x1)
    flat = np.column_stack([x_flat.ravel(), y_flat.ravel()])

    x_train = x

    # training data -> fit transfrom
    # testing and new data -> transform
    fig, axes = plt.subplots(1, 3, figsize=(13, 7))
    for n in range(0, 3):
        poly = PolynomialFeatures(n + 1, include_bias=False)
        x_poly_fit = poly.fit_transform(x_train)
        x_poly = poly.transform(flat)

        model = LinearRegression()
        model.fit(x_poly_fit, y)
        pred = model.predict(x_poly)

        axes[n].set_xlabel(file.columns[0])
        axes[n].set_ylabel(file.columns[1])
        axes[n].set_title(reg[n])

        # need to reshape in order to fit x and y values

        plot = axes[n].contourf(x_flat, y_flat, pred.reshape(x_flat.shape), levels=50, cmap='turbo', )

    cbar = plt.colorbar(plot, label=file.columns[-1], orientation='horizontal', ax=axes)
    cursor = MultiCursor(fig.canvas, axes=axes, color='white', vertOn=True, horizOn=True)

    plt.show()

# Source: https://www.datacamp.com/tutorial/variance-inflation-factor

correl_data = x
corr_matrix = correl_data.corr()
