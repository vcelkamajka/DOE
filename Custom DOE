vif_df['VIF'] = [variance_inflation_factor(vif_factors, i) for i in range(len(vif_factors.columns))] # VIF is equal to the VIF of the factors and the data indices
print(vif_df)

print(dash)
for i in range(len(vif_df['VIF'])):
    if vif_df['VIF'][i] > 5:
        print(f'VIF above 5 for {vif_df['Features'][i]}: ',round(vif_df['VIF'][i], 2)) # index of column returned for VIF > 5
        print(f'There is likely covariance with {vif_df['Features'][i]}!')
    if vif_df['VIF'][i] < 5:
        print(f'VIF below 5 for {vif_df['Features'][i]}: ',round(vif_df['VIF'][i], 2))
print(dash)

W, p_value = shapiro(file[file.columns[-1]])

print(f'The computed W value is {W:.3} and p-value is {p_value:.4}')
if p_value > 0.05:
    print('Data is normally distributed.')
else:
    print('Data is not normally distributed.')

sm.qqplot(file[file.columns[-1]], line ='s')
