np.set_printoptions(legacy='1.25') # removes the np.float in output

dash = '------------------------------------------------------------------------------'
print(dash)

#--------------------------------------------------
# Custom DOE that works on any given values - only gives graphs for 2 and 3 factors atm.
# Complete your DOE file to begin. | col 0 = variable 1, col 1 - n = variables, col n - 1 = response | Max of 3 variables CURRENTLY
# Works w/ > 3 factors, but not for any visuals - only VIF, correlation matrix and regression equations.
